import React, { useMemo, useState } from "react";

type Genre = "汎用" | "行政・自治体" | "教育" | "福祉・介護" | "防災・災害" | "事件・事故" | "裁判・法務";
type MaterialType = "取材メモ" | "文字起こし" | "行政資料" | "過去記事";
type FocusMode = "バランス型" | "スピード重視" | "正確性重視" | "深掘り重視";
type OutputTab = "概要" | "構成" | "下書き" | "確認" | "質問" | "図解" | "企画" | "AI準備";

type InputState = {
  title: string;
  centralQuestion: string;
  audience: string;
  body: string;
};

type OutputState = Record<Exclude<OutputTab, "AI準備">, string>;

const GENRES: Genre[] = ["汎用", "行政・自治体", "教育", "福祉・介護", "防災・災害", "事件・事故", "裁判・法務"];
const MATERIAL_TYPES: MaterialType[] = ["取材メモ", "文字起こし", "行政資料", "過去記事"];
const FOCUS_MODES: FocusMode[] = ["バランス型", "スピード重視", "正確性重視", "深掘り重視"];
const OUTPUT_TABS: OutputTab[] = ["概要", "構成", "下書き", "確認", "質問", "図解", "企画", "AI準備"];

const INITIAL_INPUT: InputState = {
  title: "",
  centralQuestion: "",
  audience: "",
  body: "",
};

const INITIAL_OUTPUT: OutputState = {
  概要: "",
  構成: "",
  下書き: "",
  確認: "",
  質問: "",
  図解: "",
  企画: "",
};

type ImportedAIResult = {
  summary?: string;
  structure?: string;
  draft?: string;
  checks?: string;
  questions?: string;
  diagram?: string;
  planning?: string;
};

function classNames(...parts: Array<string | false | null | undefined>): string {
  return parts.filter(Boolean).join(" ");
}

export default function KishaWorkbench(): JSX.Element {
  const [genre, setGenre] = useState<Genre>("汎用");
  const [materialType, setMaterialType] = useState<MaterialType>("取材メモ");
  const [focusMode, setFocusMode] = useState<FocusMode>("バランス型");
  const [inputs, setInputs] = useState<InputState>(INITIAL_INPUT);
  const [activeTab, setActiveTab] = useState<OutputTab>("概要");
  const [outputs, setOutputs] = useState<OutputState>(INITIAL_OUTPUT);
  const [aiPrompt, setAiPrompt] = useState<string>("");
  const [aiJsonText, setAiJsonText] = useState<string>("");
  const [notice, setNotice] = useState<string>("まずは①のサンプルで試すか、素材本文を入力してください。");

  const hasMaterial = inputs.body.trim().length > 0;
  const hasPrompt = aiPrompt.trim().length > 0;
  const hasJsonText = aiJsonText.trim().length > 0;

  const stepLabel = useMemo(() => {
    if (!hasMaterial) return "今やること：①サンプルを入れる、または素材本文を入力してください";
    if (!hasPrompt) return "今やること：②AI用プロンプトをコピーして準備を進めましょう";
    if (!hasJsonText) return "今やること：③デモAI結果を作る、またはAI結果JSONを貼り付けてください";
    return "今やること：④JSONを読み込んで確認タブで最終チェック";
  }, [hasMaterial, hasPrompt, hasJsonText]);

  const handleInputChange = (key: keyof InputState, value: string) => {
    setInputs((prev) => ({ ...prev, [key]: value }));
  };

  const buildPrompt = (): string => {
    const prompt = [
      "あなたは地方紙の編集支援AIです。次の素材をもとに、JSONで結果を返してください。",
      "必須キー: summary, structure, draft, checks, questions, diagram, planning",
      `記事ジャンル: ${genre}`,
      `素材タイプ: ${materialType}`,
      `重視モード: ${focusMode}`,
      `仮タイトル: ${inputs.title || "（未入力）"}`,
      `この記事で問いたいこと: ${inputs.centralQuestion || "（未入力）"}`,
      `想定読者: ${inputs.audience || "（未入力）"}`,
      "素材本文:",
      inputs.body || "（未入力）",
      "出力はJSONのみで返してください。",
    ].join("\n");

    setAiPrompt(prompt);
    return prompt;
  };

  const copyToClipboard = async (text: string, successMessage: string) => {
    try {
      await navigator.clipboard.writeText(text);
      setNotice(successMessage);
    } catch (error) {
      setNotice("コピーに失敗しました。手動でコピーしてください。");
    }
  };

  const fillSample = () => {
    setGenre("行政・自治体");
    setMaterialType("取材メモ");
    setFocusMode("正確性重視");
    setInputs({
      title: "イトー市、老朽化した給食センター建て替え計画",
      centralQuestion: "なぜ今の時期に建て替えが必要で、財源は妥当か",
      audience: "小中学生の保護者、地域住民、自治体政策に関心がある読者",
      body: "【取材メモ】\n- 市は築42年の給食センターを更新予定。総事業費は約38億円。\n- 市長は安全基準と災害時の炊き出し拠点機能を強調。\n- 議会からは維持管理費の見積もり不足を指摘する声。\n- 保護者アンケートでは衛生面の改善期待が高い一方、財政負担を懸念する意見も。\n- 近隣2市の同規模センター更新費は30〜35億円。",
    });
    setActiveTab("概要");
    setNotice("サンプル素材を入力しました。②へ進んでください。");
  };

  const handleCopyPrompt = async () => {
    const prompt = buildPrompt();
    setActiveTab("AI準備");
    await copyToClipboard(prompt, "AI用プロンプトをコピーしました。③へ進んでください。");
  };

  const createDemoResult = () => {
    const demo: ImportedAIResult = {
      summary: "イトー市が給食センター建て替えを急ぐ背景には、老朽化と災害対応拠点化の必要性がある。財源の妥当性と将来負担が主な論点。",
      structure: "1. 計画概要 2. 必要性（安全・防災） 3. 財源・費用比較 4. 議会と市民の懸念 5. 今後の日程",
      draft: "イトー市は老朽化した学校給食センターの建て替え計画を公表した。市は安全基準の更新と災害時活用を理由に挙げるが、議会では将来負担を巡る議論が続く。",
      checks: "・総事業費38億円の内訳確認\n・近隣市との比較条件を統一\n・維持管理費の長期推計の根拠確認",
      questions: "・補助金の見込み額は確定か\n・PFI方式の検討有無\n・完成後の運営体制は直営か委託か",
      diagram: "図1: 旧センターと新センターの比較表\n図2: 財源構成の円グラフ\n図3: 事業スケジュールのタイムライン",
      planning: "続報案: 入札公告時点での事業費再検証\n解説案: 学校給食施設の更新トレンドを県内比較",
    };
    setAiJsonText(JSON.stringify(demo, null, 2));
    setActiveTab("AI準備");
    setNotice("デモAI結果JSONを作成しました。④で読み込んでください。");
  };

  const importJson = () => {
    try {
      const parsed = JSON.parse(aiJsonText) as ImportedAIResult;
      setOutputs({
        概要: parsed.summary ?? "",
        構成: parsed.structure ?? "",
        下書き: parsed.draft ?? "",
        確認: parsed.checks ?? "",
        質問: parsed.questions ?? "",
        図解: parsed.diagram ?? "",
        企画: parsed.planning ?? "",
      });
      setActiveTab("確認");
      setNotice("JSONを取り込みました。確認タブに移動しました。");
    } catch (error) {
      setNotice("JSONの形式が正しくありません。構文を確認してください。");
    }
  };

  const copyTab = async (tab: Exclude<OutputTab, "AI準備">) => {
    const text = outputs[tab];
    if (!text.trim()) {
      setNotice(`${tab}タブの内容が空です。`);
      return;
    }
    await copyToClipboard(text, `${tab}タブの内容をコピーしました。`);
  };

  const renderSelection = <T extends string>(
    title: string,
    value: T,
    items: readonly T[],
    onChange: (item: T) => void
  ) => (
    <div>
      <p className="mb-2 text-sm font-semibold text-slate-700">{title}</p>
      <div className="grid grid-cols-2 gap-2 md:grid-cols-4">
        {items.map((item) => (
          <button
            key={item}
            type="button"
            className={classNames(
              "rounded-md border px-3 py-2 text-sm font-medium transition",
              value === item
                ? "border-red-600 bg-red-600 text-white"
                : "border-slate-300 bg-white text-slate-700 hover:border-red-300 hover:text-red-700"
            )}
            onClick={() => onChange(item)}
          >
            {item}
          </button>
        ))}
      </div>
    </div>
  );

  return (
    <main className="min-h-screen bg-slate-100 px-4 py-6 text-slate-900 md:px-8">
      <div className="mx-auto max-w-6xl space-y-4">
        <header className="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <h1 className="text-2xl font-bold tracking-tight text-slate-900">Kisha Workbench（記者ワークベンチ）</h1>
          <p className="mt-3 rounded-lg border-2 border-red-200 bg-red-50 px-4 py-3 text-lg font-bold text-red-700">{stepLabel}</p>
          <p className="mt-2 text-sm text-slate-600">{notice}</p>
        </header>

        <section className="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <div className="space-y-4">
            {renderSelection("記事ジャンル", genre, GENRES, setGenre)}
            {renderSelection("素材タイプ", materialType, MATERIAL_TYPES, setMaterialType)}
            {renderSelection("重視モード", focusMode, FOCUS_MODES, setFocusMode)}

            <div className="grid gap-3 md:grid-cols-3">
              <label className="text-sm font-medium text-slate-700">
                仮タイトル
                <input
                  className="mt-1 w-full rounded-md border border-slate-300 px-3 py-2"
                  value={inputs.title}
                  onChange={(e) => handleInputChange("title", e.target.value)}
                  placeholder="例：〇〇市、給食センター建て替え計画"
                />
              </label>
              <label className="text-sm font-medium text-slate-700">
                この記事で問いたいこと
                <input
                  className="mt-1 w-full rounded-md border border-slate-300 px-3 py-2"
                  value={inputs.centralQuestion}
                  onChange={(e) => handleInputChange("centralQuestion", e.target.value)}
                  placeholder="例：財源や意思決定は妥当か"
                />
              </label>
              <label className="text-sm font-medium text-slate-700">
                想定読者
                <input
                  className="mt-1 w-full rounded-md border border-slate-300 px-3 py-2"
                  value={inputs.audience}
                  onChange={(e) => handleInputChange("audience", e.target.value)}
                  placeholder="例：地域住民、保護者"
                />
              </label>
            </div>

            <label className="block text-sm font-medium text-slate-700">
              素材本文
              <textarea
                className="mt-1 h-44 w-full rounded-md border border-slate-300 px-3 py-2"
                value={inputs.body}
                onChange={(e) => handleInputChange("body", e.target.value)}
                placeholder="取材メモ、文字起こし、行政資料、過去記事などを貼り付け"
              />
            </label>
          </div>
        </section>

        <section className="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 className="mb-3 text-lg font-bold text-slate-900">操作ステップ</h2>
          <div className="grid gap-2 md:grid-cols-4">
            <button className="rounded-md bg-slate-900 px-3 py-2 text-sm font-bold text-white hover:bg-slate-700" onClick={fillSample}>
              ① サンプルで試す
            </button>
            <button
              className="rounded-md bg-red-600 px-3 py-2 text-sm font-bold text-white disabled:cursor-not-allowed disabled:bg-slate-300"
              onClick={handleCopyPrompt}
              disabled={!hasMaterial}
            >
              ② AI用プロンプトをコピー
            </button>
            <button
              className="rounded-md bg-slate-800 px-3 py-2 text-sm font-bold text-white disabled:cursor-not-allowed disabled:bg-slate-300"
              onClick={createDemoResult}
              disabled={!hasPrompt}
            >
              ③ デモAI結果を作る
            </button>
            <button
              className="rounded-md bg-red-700 px-3 py-2 text-sm font-bold text-white disabled:cursor-not-allowed disabled:bg-slate-300"
              onClick={importJson}
              disabled={!hasJsonText}
            >
              ④ 貼り付けたJSONを読み込む
            </button>
          </div>
        </section>

        <section className="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <div className="mb-4 flex flex-wrap gap-2">
            {OUTPUT_TABS.map((tab) => (
              <button
                key={tab}
                type="button"
                onClick={() => setActiveTab(tab)}
                className={classNames(
                  "rounded-md border px-3 py-1.5 text-sm font-semibold",
                  activeTab === tab ? "border-red-600 bg-red-600 text-white" : "border-slate-300 bg-white text-slate-700"
                )}
              >
                {tab}
              </button>
            ))}
          </div>

          {activeTab === "AI準備" ? (
            <div className="space-y-3">
              <label className="block text-sm font-medium text-slate-700">
                AI用プロンプト
                <textarea className="mt-1 h-40 w-full rounded-md border border-slate-300 px-3 py-2" value={aiPrompt} readOnly />
              </label>
              <button
                type="button"
                className="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 disabled:cursor-not-allowed disabled:bg-slate-100"
                onClick={() => copyToClipboard(aiPrompt, "AI用プロンプトをコピーしました。")}
                disabled={!hasPrompt}
              >
                AI用プロンプトをコピー
              </button>

              <label className="block text-sm font-medium text-slate-700">
                AI結果JSON
                <textarea
                  className="mt-1 h-56 w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-xs"
                  value={aiJsonText}
                  onChange={(e) => setAiJsonText(e.target.value)}
                  placeholder='{"summary":"...","structure":"..."}'
                />
              </label>
            </div>
          ) : (
            <div className="space-y-3">
              <textarea
                className="h-56 w-full rounded-md border border-slate-300 px-3 py-2"
                value={outputs[activeTab as Exclude<OutputTab, "AI準備">]}
                onChange={(e) =>
                  setOutputs((prev) => ({
                    ...prev,
                    [activeTab]: e.target.value,
                  }))
                }
              />
              <button
                type="button"
                onClick={() => copyTab(activeTab as Exclude<OutputTab, "AI準備">)}
                className="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700"
              >
                このタブをコピー
              </button>
            </div>
          )}
        </section>
      </div>
    </main>
  );
}
