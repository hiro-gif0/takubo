            { speaker: 'iyanagi', text: 'やっぱり「議会解散」の可能性の方が高いんじゃないかしら。ええ。政治家というものは、権力の座にいる限り、最後まで戦う道を探るものなんです。刑事告発っていう逆風でさえ、支持者を固める燃料に変えちゃうかもしれないわ。9月11日、私たちは歴史的決断の目撃者になるかもしれません。' },
            { speaker: 'system', text: 'さあ、物語は最終局面へ。イトー市の未来はどうなるのか…！' }
        ],
        finalChoices: [
            { id: "dissolve", title: "議会を解散" },
            { id: "resign", title: "自ら辞職" }
        ],
        endings: [
            { 
                id: 'continue', 
                title: 'ENDING: 茨の道は続く…', 
                visual: '<div class="ending-visual-sprout">🌱</div>',
                sound: '[かすかな希望の音が、静かに響き始める… ]',
                text: '「夢想の改革者」は、市民に最後の審判を委ねた。議会解散という茨の道。それは、混乱の終わりか、それとも新たな始まりか。小さな改革の芽は、果たしてこのカオスの中で育つのだろうか。<br><br><span class="text-yellow-300">TO BE CONTINUED...?</span>'
            },
            {
                id: 'gameover',
                title: 'ENDING: GAME OVER',
                visual: '<div class="ending-visual-sunset"></div>',
                sound: '[静かに、物語の終わりを告げる音が響く… ]',
                text: '「夢想の改革者」の挑戦は、ここで幕を閉じた。市民派を掲げたその夢は、まるで夕日に溶けるように消えていく…。市政改革のクエストは、また別の冒険者に引き継がれるのだろうか。あるいは…。<br><br><span class="text-red-400">THE END</span>'
            }
        ]
    };

    // --- Elements ---
    const mainContainer = document.getElementById('main-container');
    const trustValue = document.getElementById('trust-value');
    const trustBar = document.getElementById('trust-bar');
    const stanceSelector = document.getElementById('stance-selector');
    const timelineContainer = document.getElementById('timeline-container');
    const issueGrid = document.getElementById('issue-grid');
    const startBattleBtn = document.getElementById('start-battle-btn');
    const battleArena = document.getElementById('battle-arena');
    const animationLayer = document.getElementById('animation-layer');
    const battleMessage = document.getElementById('battle-message');
    const mayorCard = document.getElementById('mayor-card');
    const councilCard = document.getElementById('council-card');
    const mayorHp = document.getElementById('mayor-hp');
    const councilHp = document.getElementById('council-hp');
    const dialogueArea = document.getElementById('dialogue-area');
    const finalChapter = document.getElementById('chapter5');
    const finalChoices = document.getElementById('final-choices');
    const endingScreen = document.getElementById('ending-screen');

    let state = {
        trust: 50,
        mayorHealth: 100,
        councilHealth: 100
    };

    // --- Initialization ---
    function init() {
        updateTrustGauge(state.trust);

        DATA.stances.forEach(s => {
            const button = document.createElement('button');
            button.className = 'stance-btn p-2 border-2 border-white pixel-font hover:bg-blue-900 transition';
            button.dataset.id = s.id;
            button.textContent = s.label;
            button.addEventListener('click', () => selectStance(s));
            stanceSelector.appendChild(button);
        });

        DATA.timeline.forEach((t) => {
            const card = document.createElement('div');
            card.className = 'stagger-item p-3 text-center w-40';
            card.style.backgroundColor = 'var(--bg-card)';
            card.innerHTML = `
                <div class="text-3xl">${t.icon}</div>
                <h3 class="pixel-font text-yellow-300 mt-1 h-10 flex items-center justify-center">${t.event}</h3>
                <p class="mt-2 text-xs">${t.detail}</p>
            `;
            const arrowContainer = document.createElement('div');
            arrowContainer.className = 'stagger-item flex items-center';
            arrowContainer.innerHTML = `
                <div class="text-2xl text-yellow-300 pixel-font hidden md:block mx-2">→</div>
                <div class="text-2xl text-yellow-300 pixel-font md:hidden my-2">↓</div>
            `;
            timelineContainer.appendChild(card);
            timelineContainer.appendChild(arrowContainer);
        });
        timelineContainer.lastChild.remove();


        DATA.issues.forEach(i => {
            const card = document.createElement('div');
            card.className = 'stagger-item p-3 text-center';
            card.style.backgroundColor = 'var(--bg-card)';
            card.innerHTML = `
                <div class="text-3xl">${i.icon}</div>
                <h3 class="pixel-font text-yellow-300 mt-1">${i.name}</h3>
                <p class="mt-2 text-xs">${i.detail}</p>
            `;
            issueGrid.appendChild(card);
        });
       
        DATA.finalChoices.forEach(s => {
            const choiceBtn = document.createElement('button');
            choiceBtn.className = 'p-4 border-2 border-white pixel-font text-lg hover:bg-blue-900 transition';
            choiceBtn.textContent = s.title;
            if (s.id === "dissolve") {
                choiceBtn.addEventListener('click', () => handleFinalChoice('dissolve'));
            } else {
                choiceBtn.addEventListener('click', () => handleFinalChoice('resign'));
            }
            finalChoices.appendChild(choiceBtn);
        });

        startBattleBtn.addEventListener('click', startBattle);
        setupScrollAnimations();
    }

    // --- Functions ---
    function typewriter(element, text, speed) {
        return new Promise(resolve => {
            let i = 0;
            const cursor = document.createElement('span');
            cursor.className = 'typing-cursor';
            element.innerHTML = '';
            element.appendChild(cursor);
           
            function type() {
                if (i < text.length) {
                    cursor.before(text.charAt(i));
                    i++;
                    setTimeout(type, speed);
                } else {
                    cursor.remove();
                    resolve();
                }
            }
            type();
        });
    }
   
    async function startDialogue() {
        dialogueArea.innerHTML = '';
        for (const dialogue of DATA.dialogue) {
            if (dialogue.speaker === 'system') {
                const systemMessage = document.createElement('p');
                systemMessage.className = 'text-center pixel-font text-yellow-300 py-2';
                dialogueArea.appendChild(systemMessage);
                await typewriter(systemMessage, dialogue.text, 50);
            } else {
                const messageWrapper = document.createElement('div');
                messageWrapper.className = 'flex items-start gap-3 dialogue-wrapper';

                const avatar = document.createElement('div');
                avatar.className = 'dialogue-avatar';
               
                const bubble = document.createElement('div');
                bubble.className = 'dialogue-bubble';

                const name = document.createElement('p');
                name.className = 'pixel-font text-sm mb-1';
               
                const textElement = document.createElement('p');
                textElement.className = 'text-sm';
                textElement.textContent = dialogue.text;

                if (dialogue.speaker === 'aochan') {
                    avatar.textContent = '👨‍🦲';
                    name.textContent = 'イトー支局長 アオチャン';
                    name.style.color = '#63b3ed'; // blue-400
                    bubble.classList.add('dialogue-bubble-left');
                    messageWrapper.appendChild(avatar);
                    messageWrapper.appendChild(bubble);
                    messageWrapper.classList.add('slide-in-left');
                } else { // iyanagi
                    avatar.textContent = '👩‍🏫';
                    name.textContent = '政治学者 イヤナギ先生';
                    name.style.color = '#68d391'; // green-400
                    bubble.classList.add('dialogue-bubble-right');
                    messageWrapper.appendChild(bubble);
                    messageWrapper.appendChild(avatar);
                    messageWrapper.classList.add('slide-in-right');
                }
               
                bubble.appendChild(name);
                bubble.appendChild(textElement);
                dialogueArea.appendChild(messageWrapper);
            }
            await new Promise(resolve => setTimeout(resolve, 3000));
        }
        finalChapter.classList.remove('hidden');
        finalChapter.classList.add('fade-in');
    }

    function updateTrustGauge(value) {
        state.trust = Math.max(0, Math.min(100, value));
        trustValue.textContent = state.trust;
        trustBar.style.width = `${state.trust}%`;
    }

    function selectStance(stance) {
        updateTrustGauge(stance.trust);
        document.querySelectorAll('.stance-btn').forEach(btn => btn.setAttribute('aria-selected', 'false'));
        document.querySelector(`.stance-btn[data-id="${stance.id}"]`).setAttribute('aria-selected', 'true');
    }

    function playAttackAnimation(log) {
        const icon = document.createElement('div');
        icon.className = 'attack-icon';
        icon.textContent = log.icon;
        animationLayer.appendChild(icon);

        if (log.turn === 'council' || log.turn === 'nanba') {
            icon.style.right = '25%';
            icon.style.top = '20%';
            icon.classList.add('attack-anim-mayor');
        } else {
            icon.style.left = '25%';
            icon.style.top = '20%';
            icon.classList.add('attack-anim-council');
        }

        setTimeout(() => icon.remove(), 1500);
    }

    async function startBattle() {
        document.getElementById('start-battle-wrapper').classList.add('hidden');
        battleArena.classList.remove('hidden');
       
        for (const log of DATA.battleLog) {
            await new Promise(resolve => setTimeout(resolve, 2000));
           
            let attackerName, attackerColor, targetCard, targetHpBar, targetHealthKey;

            if (log.turn === 'system') {
                battleMessage.innerHTML = `<p class="text-yellow-300">${log.text}</p>`;
            } else {
                if (log.turn === 'mayor') {
                    attackerName = 'タクボ';
                    attackerColor = 'text-red-400';
                    targetCard = councilCard;
                    targetHpBar = councilHp;
                    targetHealthKey = 'councilHealth';
                } else {
                    attackerName = (log.turn === 'nanba') ? 'ウィッグの盟主 ナンバ' : 'ギカイ';
                    attackerColor = (log.turn === 'nanba') ? 'text-purple-400' : 'text-blue-400';
                    targetCard = mayorCard;
                    targetHpBar = mayorHp;
                    targetHealthKey = 'mayorHealth';
                }
               
                if (log.special === 'nanba_repel') {
                    battleMessage.innerHTML = `<p><span class="${attackerColor}">${attackerName}</span> の <span class="text-yellow-300">${log.skill}</span>！ナンバを撃退した！</p>`;
                } else if (log.trustDamage) {
                    battleMessage.innerHTML = `<p><span class="${attackerColor}">${attackerName}</span> は <span class="text-yellow-300">${log.skill}</span> を発動！相手にダメージはないが、市民の信頼が失われていく…。</p>`;
                } else {
                    battleMessage.innerHTML = `<p><span class="${attackerColor}">${attackerName}</span> の攻撃！ <span class="text-yellow-300">${log.skill}</span>！</p>`;
                }
               
                if(log.icon) playAttackAnimation(log);
               
                await new Promise(resolve => setTimeout(resolve, 600));

                if (log.damage > 0) {
                    state[targetHealthKey] -= log.damage;
                    targetHpBar.style.width = `${Math.max(0, state[targetHealthKey])}%`;
                    targetCard.classList.add('damage-animation');
                }
                if (log.heal > 0) {
                    state.mayorHealth = Math.min(100, state.mayorHealth + log.heal);
                    mayorHp.style.width = `${state.mayorHealth}%`;
                    mayorCard.classList.add('heal-animation');
                }
                if (log.trustDamage) {
                    updateTrustGauge(state.trust - log.trustDamage);
                }

                mainContainer.classList.add('screen-shake');
                setTimeout(() => {
                    targetCard.classList.remove('damage-animation');
                    mayorCard.classList.remove('heal-animation');
                    mainContainer.classList.remove('screen-shake');
                }, 500);
            }
        }
       
        // --- ADDED: Start Chapter 4 after battle ---
        await new Promise(resolve => setTimeout(resolve, 2000)); // Wait for the last message to be read
        const chapter4 = document.getElementById('chapter4');
        chapter4.classList.add('is-visible'); // Make the section visible
        chapter4.scrollIntoView({ behavior: 'smooth', block: 'start' });
        await startDialogue();
        // --- END ADDITION ---
    }
   
    function handleFinalChoice(choiceId) {
        document.querySelectorAll('.flow-path-item').forEach(el => el.classList.remove('highlighted'));
       
        const pathItems = document.querySelectorAll(`[data-path-id^="${choiceId}"], [data-path-id="start"], [data-path-id="choice-point"]`);
        pathItems.forEach(item => item.classList.add('highlighted'));

        document.getElementById('choice-prompt-wrapper').classList.add('hidden');
       
        setTimeout(() => {
            const ending = (choiceId === 'dissolve') ? DATA.endings[0] : DATA.endings[1];
             endingScreen.innerHTML = `
                <h3 class="text-2xl pixel-font text-yellow-300 mb-4">${ending.title}</h3>
                ${ending.visual}
                <p class="text-sm text-gray-400 italic my-4">${ending.sound}</p>
                <p class="text-base pixel-font leading-relaxed">${ending.text}</p>
            `;
            endingScreen.classList.remove('hidden');
            endingScreen.classList.add('fade-in');
        }, 2000);
    }
   
    function setupScrollAnimations() {
        // This promise chain ensures that each major animation sequence (like a chapter appearing)
        // completes before the next one starts, even if the user scrolls quickly.
        // It prevents animations from overlapping and creating a jarring experience.
        let animationPromise = Promise.resolve();
       
        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const el = entry.target;
                    observer.unobserve(el);
                   
                    animationPromise = animationPromise.then(() => {
                        return new Promise(async (resolve) => {
                            const animationType = el.dataset.animation;
                            el.classList.add('is-visible');

                            if (animationType === 'opening-chain') {
                                // Wait for the title's CSS animation to have time to play out
                                await new Promise(r => setTimeout(r, 6500));
                                const elementsToType = el.querySelectorAll('[data-animation-chain]');
                                for(const chainEl of elementsToType) {
                                    chainEl.style.opacity = '1';
                                    await typewriter(chainEl, chainEl.textContent, 80);
                                }
                            } else if (animationType === 'stagger-children') {
                                const children = el.querySelectorAll('.stagger-item');
                                for (const child of children) {
                                    child.classList.add('is-visible');
                                    await new Promise(r => setTimeout(r, 1500));
                                }
                            } else if (animationType === 'battle') {
                                const pushIndicator = el.querySelector('#push-indicator');
                                pushIndicator.classList.add('is-visible'); 
                                await new Promise(r => setTimeout(r, 3000));
                                pushIndicator.classList.add('fade-out');
                            } else if (animationType === 'dialogue') {
                                // This is now triggered by the battle completion, not scroll.
                                // await startDialogue();
                            }
                            resolve();
                        });
                    });
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('[data-animation-section]').forEach((section) => {
            if(section.id === 'opening') section.dataset.animation = 'opening-chain';
            else if (section.id === 'chapter1' || section.id === 'chapter2') section.dataset.animation = 'stagger-children';
            else if (section.id === 'chapter3') section.dataset.animation = 'battle';
            // REMOVED: else if (section.id === 'chapter4') section.dataset.animation = 'dialogue';
            observer.observe(section);
        });
    }

    init();
});
</script>

