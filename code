            { name: "虚偽証言(地自法違反)", detail: "百条委での「6月28日に初めて知った」等の証言が虚偽と断定され、刑事告発へ。", icon: "✍️" },
            { name: "対立の構造", detail: "新図書館建設やメガソーラーに反対する市長の公約と、それを推進してきた議会多数派との根深い対立が背景にある。", icon: "⚔️"},
            { name: "【NEW】行政ストップ", detail: "焼却炉補修費など約6億円の予算が止まり、市民サービスに具体的な影響が出始める。", icon: "🛑"}
        ],
        battleLog: [
            { turn: 'council', skill: '百条委員会の剣', icon: '⚔️', damage: 15 },
            { turn: 'mayor', skill: '黙秘権の盾', icon: '🛡️', damage: 10 },
            { turn: 'council', skill: '包囲網作戦', icon: '🕸️', damage: 20 },
            { turn: 'mayor', skill: '【秘技】論点ずらしの19.2秒', icon: '⏳', heal: 25, trustDamage: 20 },
            { turn: 'system', text: '突如、大都市から援軍が現れた！' },
            { turn: 'nanba', skill: '奇策：メガソーラー', icon: '👨‍🦳', damage: 20 },
            { turn: 'mayor', skill: '【奥義】目くらましSNS活用術', icon: '📱', damage: 25, special: 'nanba_repel' },
            { turn: 'system', text: 'しかし、あの男が再び…！' },
            { turn: 'nanba', skill: '【最終見解】これは事実です。以上', icon: '👨‍🦳', damage: 25, special: 'nanba_flee' },
            { turn: 'system', text: 'ナンバは言いたいことだけ言うと、颯爽と去っていった…' },
            { turn: 'council', skill: '【伝家の宝刀】不信任決議', icon: '💥', damage: 30 },
            { turn: 'system', text: '両者の対立は激化し、市政は完全に機能不全に陥った…' }
        ],
        dialogue: [
